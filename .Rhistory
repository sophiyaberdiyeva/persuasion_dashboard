# ============================================================
#  HELPER: reusable bar-chart function
# ============================================================
bar_chart <- function(df, col, title, x_lab = NULL, flip = FALSE,
palette = PAL) {
counts <- df |>
count(.data[[col]], name = "n") |>
filter(!is.na(.data[[col]])) |>
mutate(label = .data[[col]])
p <- counts |>
ggplot(aes(x = if (flip) reorder(label, n) else label,
y = n,
fill = label,
text = paste0(label, ": ", n))) +
geom_col(show.legend = FALSE) +
scale_fill_manual(values = rep_len(palette, nrow(counts))) +
scale_y_continuous(expand = expansion(mult = c(0, .12))) +
labs(title = title, x = x_lab, y = "Count") +
theme_minimal(base_size = 12) +
theme(plot.title = element_text(size = 11, face = "bold"),
axis.text.x = element_text(angle = if (!flip) 30 else 0,
hjust = 1, size = 8))
if (flip) p <- p + coord_flip()
ggplotly(p, tooltip = "text") |> layout(showlegend = FALSE)
}
