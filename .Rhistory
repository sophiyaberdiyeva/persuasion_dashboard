#freq(DATA03$KIDS)
#mean(DATA03$KIDS)
# Var: Age (categorical)
DATA03$AGE_C <- "NA"
DATA03$AGE_C[DATA03$AGE>=18] <- "18-25"
DATA03$AGE_C[DATA03$AGE>=25] <- "26-39"
DATA03$AGE_C[DATA03$AGE>=40] <- "40-59"
DATA03$AGE_C[DATA03$AGE>=60] <- "60+"
DATA03$AGE_C <- as.factor(DATA03$AGE_C)
# Recoding sex
DATA03$SEX <- as_factor(DATA03$SEX)
DATA03$URBRURAL <- as_factor(DATA03$URBRURAL)
# Check new variable
#freq(DATA03$AGE_C)
# Var: Equalized Household Income
DATA03$INCOME01 = DATA03$JP_INC
DATA03$INCOME02 = DATA03$JP_INC / (1 + DATA03$OTHER*0.5 + DATA03$KIDS*0.3)
# Var: AROP (At-Risk-Of-Poverty)
DATA03$POOR <- "Not poor"
DATA03$POOR[DATA03$INCOME02 < (median(DATA03$INCOME02)*0.6)] <- "Poor"
DATA03$POOR <- as.factor(DATA03$POOR)
